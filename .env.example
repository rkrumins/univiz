# ══════════════════════════════════════════════════════════════════════
# Synodic — Local Dev Env Template
# ══════════════════════════════════════════════════════════════════════
# Copy to .env.dev and sourced by ./dev.sh:
#   cp .env.example .env.dev
#   ./dev.sh
#
# Format: KEY=VALUE (no `export` keyword — dev.sh auto-exports).
# This file is safe to check in. .env.dev is gitignored.
# ══════════════════════════════════════════════════════════════════════

# ── Postgres (shared by docker-compose.dev.yml and the backend) ──────
POSTGRES_USER=synodic
POSTGRES_PASSWORD=synodic
POSTGRES_DB=synodic
POSTGRES_PORT=5432

# ── Redis (aggregation message broker) ──────────────────────────────
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# ── FalkorDB (graph database) ───────────────────────────────────────
FALKORDB_PORT=6379
FALKORDB_UI_PORT=3000
FALKORDB_HOST=localhost
FALKORDB_GRAPH_NAME=nexus_lineage

# Host-dev only: when running the backend / insights-service ON THE HOST
# (not in a container) against the `./dev.sh up` or `./dev.sh infra`
# FalkorDB, the provider row stores the Docker hostname `falkordb`, which
# the host cannot resolve. Set true so FALKORDB_HOST/FALKORDB_PORT above
# override the stored host for falkordb providers. NOT injected into
# compose service env, so in-container services are unaffected.
LOCAL_DEV_FALKORDB_OVERRIDE=true

# ── Backend connection strings (derived from the above) ─────────────
MANAGEMENT_DB_URL=postgresql+asyncpg://synodic:synodic@localhost:5432/synodic

# ── Auth ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
ADMIN_EMAIL=admin@nexuslineage.local
ADMIN_PASSWORD=admin123

# ── Graph Provider Bootstrap ────────────────────────────────────────
GRAPH_PROVIDER=falkordb

# ── Credential Encryption ───────────────────────────────────────────
# CREDENTIAL_ENCRYPTION_KEY=   # Fernet key; omit for plaintext in dev

# ── CORS ────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3080,http://localhost:5173,http://localhost:3000

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Timeouts (backend) ──────────────────────────────────────────────
# All values centralised in backend/app/config/resilience.py. Override
# any of them here without code changes; defaults match the file.
# TRACE_TIMEOUT_SECS=60                # outer budget for /trace + /trace/expand
# HTTP_TIMEOUT_TRACE_SECS=60           # ASGI middleware budget for trace routes
# HTTP_TIMEOUT_GRAPH_SECS=15           # generic /graph/* routes
# HTTP_TIMEOUT_AGGREGATION_SECS=45     # /edges/aggregated + /aggregation/*
# HTTP_TIMEOUT_DEFAULT_SECS=30         # fallback for any other endpoint
# FALKORDB_QUERY_TIMEOUT=5             # default per-query read deadline
# FALKORDB_WRITE_TIMEOUT=15            # default per-query write deadline
# FALKORDB_CHILDREN_QUERY_TIMEOUT=15   # get_children / get_children_with_edges
# FALKORDB_EDGES_BETWEEN_TIMEOUT=40    # /edges/between urn-set edge resolve

# ── Timeouts (frontend, via Vite — ms, not seconds) ─────────────────
# Centralised in frontend/src/config/timeouts.ts. Per-call overrides
# live next to the call site (e.g. RemoteGraphProvider.getAggregatedEdges).
# VITE_TIMEOUT_DEFAULT_MS=30000        # generic fetch wrapper default
# VITE_TIMEOUT_TRACE_MS=60000          # /trace/v2 + /trace/expand
# VITE_TIMEOUT_GET_CHILDREN_MS=30000   # /nodes/:urn/children(-with-edges)
# VITE_TIMEOUT_AGGREGATED_EDGES_MS=45000  # /edges/aggregated
# VITE_TIMEOUT_EDGES_BETWEEN_MS=45000     # /edges/between (urn-set edge fetch)
# VITE_TIMEOUT_PROVIDER_HEALTH_MS=30000   # /health/providers + per-provider /test
